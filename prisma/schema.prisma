generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("starter")
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   User[]
}

model User {
  id              String           @id @default(cuid())
  clerkId         String           @unique
  email           String           @unique
  name            String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  role            String           @default("owner")
  seats           Int              @default(1)
  teamId          String?
  apiKeys         ApiKey[]
  cardIdentity    CardIdentity?
  clients         Client[]
  closeSessions   CloseSession[]
  feedback        Feedback[]
  leads           Lead[]
  proposals       Proposal[]
  servicePackages ServicePackage[]
  subscription    Subscription?
  team            Team?            @relation(fields: [teamId], references: [id])
  events          UserEvent[]
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  key       String    @unique
  name      String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model CardIdentity {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  brandColour             String   @default("#C4973F")
  accentColour            String   @default("#E8B44B")
  logoUrl                 String?
  agencyName              String?
  agencyTagline           String?
  writingStyle            String?
  defaultAngle            String   @default("pain")
  ctaType                 String   @default("reply")
  ctaValue                String?
  socialProof             Json?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  agencyOwnerName         String?
  agencyOwnerPhoto        String?
  cardStyle               String   @default("editorial")
  closeIntroText          String?
  defaultResponseTime     String   @default("24 hours")
  agencyEmail             String?
  agencyWebsite           String?
  deliverableReminderDays Int      @default(2)
  healthAlertThreshold    Int      @default(60)
  reportAutoSend          Boolean  @default(false)
  reportSchedule          String   @default("manual")
  useColdCall             Boolean  @default(true)
  useVideoMessage         Boolean  @default(false)
  user                    User     @relation(fields: [userId], references: [id])
}

model Lead {
  id                 String         @id @default(cuid())
  userId             String
  businessName       String
  ownerName          String?
  location           String
  niche              String
  website            String?
  phone              String?
  email              String?
  googlePlaceId      String?
  googleRating       Float?
  reviewCount        Int?
  reviewSummary      Json?
  instagramHandle    String?
  instagramData      Json?
  websiteAudit       Json?
  techStack          Json?
  intentScore        String         @default("medium")
  intentSignals      Json?
  businessBio        String?
  observations       Json?
  openingLine        String?
  recommendedChannel String?
  suggestedAngle     String?
  status             String         @default("pending")
  jobId              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  pipelineStage      String         @default("new")
  card               Card?
  arsenal            OutreachArsenal?
  clients            Client[]
  closeSessions      CloseSession[]
  user               User           @relation(fields: [userId], references: [id])
  proposals          Proposal[]
  sequence           Sequence?
}

model Sequence {
  id           String         @id @default(cuid())
  leadId       String         @unique
  userId       String
  status       String         @default("active")
  currentStep  Int            @default(0)
  nextActionAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lead         Lead           @relation(fields: [leadId], references: [id])
  steps        SequenceStep[]
}

model SequenceStep {
  id          String    @id @default(cuid())
  sequenceId  String
  stepNumber  Int
  channel     String
  subject     String?
  message     String
  angle       String
  status      String    @default("pending")
  scheduledAt DateTime
  sentAt      DateTime?
  repliedAt   DateTime?
  sequence    Sequence  @relation(fields: [sequenceId], references: [id])
}

model Card {
  id               String    @id @default(cuid())
  slug             String    @unique
  leadId           String    @unique
  userId           String
  headline         String?
  observations     Json?
  revenueLoss      String?
  ctaText          String?
  ctaValue         String?
  brandColour      String?
  logoUrl          String?
  agencyName       String?
  viewCount        Int       @default(0)
  lastViewed       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  approachMoves    Json?
  deliveryMessages Json?
  minutesAnalysing Int?
  personalNote     String?
  revenueBreakdown Json?
  signalBanner     String?
  lead             Lead      @relation(fields: [leadId], references: [id])
}

model Subscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  stripeCustomerId    String?
  stripePriceId       String?
  stripeSubId         String?
  plan                String    @default("starter")
  status              String    @default("active")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  activityQualified   Boolean   @default(false)
  cardCount           Int       @default(0)
  dealClientName      String?
  dealClosed          Boolean   @default(false)
  dealClosedAt        DateTime?
  dealLeadId          String?
  dealValue           Float?
  isSolopreneur       Boolean   @default(false)
  searchCount         Int       @default(0)
  solopreneurApproved Boolean   @default(false)
  solopreneurExpiry   DateTime?
  user                User      @relation(fields: [userId], references: [id])
}

model SolopreneurApplication {
  id           String   @id @default(cuid())
  userId       String
  email        String
  name         String
  agency       String?
  teamSize     String?
  niche        String?
  monthlySpend String?
  notes        String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserEvent {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model Feedback {
  id            String    @id @default(cuid())
  userId        String
  message       String
  implemented   Boolean   @default(false)
  implementedAt DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
}

model Proposal {
  id                String             @id @default(cuid())
  slug              String             @unique
  leadId            String
  userId            String
  title             String
  threadSection     String?
  currentState      String?
  visionSection     String?
  planSection       Json?
  beforeAfter       Json?
  investmentContext String?
  closingSection    String?
  depositAmount     Float?
  status            String             @default("draft")
  stripeSessionId   String?
  viewCount         Int                @default(0)
  firstViewedAt     DateTime?
  lastViewedAt      DateTime?
  acceptedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lead              Lead               @relation(fields: [leadId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  questions         ProposalQuestion[]
}

model ProposalQuestion {
  id          String    @id @default(cuid())
  proposalId  String
  visitorName String
  question    String
  answer      String?
  isPublic    Boolean   @default(true)
  answeredAt  DateTime?
  createdAt   DateTime  @default(now())
  proposal    Proposal  @relation(fields: [proposalId], references: [id])
}

model ServicePackage {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  price       Float
  currency    String   @default("GBP")
  features    Json?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model CloseSession {
  id                   String            @id @default(cuid())
  leadId               String
  userId               String
  slug                 String            @unique
  status               String            @default("sent")
  questions            Json
  answers              Json?
  discoveryViewedAt    DateTime?
  discoveryCompletedAt DateTime?
  proposalId           String?
  proposalGeneratedAt  DateTime?
  viewCount            Int               @default(0)
  lastViewed           DateTime?
  completionRate       Float?
  sentMessage          String?
  sentChannel          String?
  sentAt               DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  lead                 Lead              @relation(fields: [leadId], references: [id])
  user                 User              @relation(fields: [userId], references: [id])
  discoveryAnswers     DiscoveryAnswer[]
}

model DiscoveryAnswer {
  id             String       @id @default(cuid())
  closeSessionId String
  questionIndex  Int
  questionText   String
  answer         String
  answeredAt     DateTime     @default(now())
  closeSession   CloseSession @relation(fields: [closeSessionId], references: [id])
}

model Client {
  id              String           @id @default(cuid())
  userId          String
  leadId          String?
  proposalId      String?
  businessName    String
  ownerName       String?
  email           String?
  phone           String?
  website         String?
  niche           String?
  location        String?
  logoUrl         String?
  status          String           @default("active")
  startDate       DateTime         @default(now())
  contractValue   Float?
  billingCycle    String           @default("monthly")
  nextBillingDate DateTime?
  contractEndDate DateTime?
  healthScore     Int              @default(100)
  healthSignals   Json?
  lastHealthCheck DateTime?
  notes           String?
  tags            Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lead            Lead?            @relation(fields: [leadId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  activities      ClientActivity[]
  checkIns        ClientCheckIn[]
  reports         ClientReport[]
  deliverables    Deliverable[]
}

model Deliverable {
  id          String    @id @default(cuid())
  clientId    String
  userId      String
  title       String
  description String?
  category    String
  status      String    @default("pending")
  priority    String    @default("medium")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id])
}

model ClientReport {
  id        String    @id @default(cuid())
  clientId  String
  userId    String
  slug      String    @unique
  title     String
  period    String
  content   Json
  status    String    @default("draft")
  sentAt    DateTime?
  viewedAt  DateTime?
  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  client    Client    @relation(fields: [clientId], references: [id])
}

model ClientCheckIn {
  id          String    @id @default(cuid())
  clientId    String
  userId      String
  type        String
  notes       String?
  sentiment   String?
  nextAction  String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientId], references: [id])
}

model ClientActivity {
  id          String   @id @default(cuid())
  clientId    String
  userId      String
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id])
}

model OutreachArsenal {
  id                 String   @id @default(cuid())
  leadId             String   @unique
  userId             String
  voiceNoteScript    String?
  coldCallScript     Json?
  linkedinNote       String?
  linkedinFollowUp1  String?
  linkedinFollowUp2  String?
  emailSubject1      String?
  emailBody1         String?
  emailSubject2      String?
  emailBody2         String?
  emailSubject3      String?
  emailBody3         String?
  videoScript        Json?
  channelStatus      Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lead               Lead     @relation(fields: [leadId], references: [id])
}
