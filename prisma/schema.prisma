generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("starter")
  ownerId   String
  members   User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id              String           @id @default(cuid())
  clerkId         String           @unique
  email           String           @unique
  name            String?
  teamId          String?
  team            Team?            @relation(fields: [teamId], references: [id])
  role            String           @default("owner")
  seats           Int              @default(1)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cardIdentity    CardIdentity?
  leads           Lead[]
  subscription    Subscription?
  apiKeys         ApiKey[]
  events          UserEvent[]
  feedback        Feedback[]
  proposals       Proposal[]
  servicePackages ServicePackage[]
  closeSessions   CloseSession[]
  clients         Client[]
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  key       String    @unique
  name      String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
}

model CardIdentity {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  brandColour      String   @default("#C4973F")
  accentColour     String   @default("#E8B44B")
  logoUrl          String?
  agencyName       String?
  agencyTagline    String?
  agencyOwnerName  String?
  agencyOwnerPhoto String?
  writingStyle     String?
  defaultAngle     String   @default("pain")
  ctaType          String   @default("reply")
  ctaValue         String?
  cardStyle            String   @default("editorial")
  socialProof          Json?
  defaultResponseTime  String   @default("24 hours")
  closeIntroText       String?
  agencyWebsite        String?
  agencyEmail          String?
  reportSchedule       String   @default("manual")
  reportAutoSend       Boolean  @default(false)
  healthAlertThreshold Int      @default(60)
  deliverableReminderDays Int   @default(2)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Lead {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  businessName       String
  ownerName          String?
  location           String
  niche              String
  website            String?
  phone              String?
  email              String?
  googlePlaceId      String?
  googleRating       Float?
  reviewCount        Int?
  reviewSummary      Json?
  instagramHandle    String?
  instagramData      Json?
  websiteAudit       Json?
  techStack          Json?
  intentScore        String    @default("medium")
  intentSignals      Json?
  businessBio        String?
  observations       Json?
  openingLine        String?
  recommendedChannel String?
  suggestedAngle     String?
  status             String    @default("pending")
  pipelineStage      String    @default("new")
  jobId              String?
  card               Card?
  sequence           Sequence?
  proposals          Proposal[]
  closeSessions      CloseSession[]
  clients            Client[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Sequence {
  id           String         @id @default(cuid())
  leadId       String         @unique
  lead         Lead           @relation(fields: [leadId], references: [id])
  userId       String
  status       String         @default("active")
  currentStep  Int            @default(0)
  nextActionAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  steps        SequenceStep[]
}

model SequenceStep {
  id          String    @id @default(cuid())
  sequenceId  String
  sequence    Sequence  @relation(fields: [sequenceId], references: [id])
  stepNumber  Int
  channel     String
  subject     String?
  message     String
  angle       String
  status      String    @default("pending")
  scheduledAt DateTime
  sentAt      DateTime?
  repliedAt   DateTime?
}

model Card {
  id               String    @id @default(cuid())
  slug             String    @unique
  leadId           String    @unique
  lead             Lead      @relation(fields: [leadId], references: [id])
  userId           String
  headline         String?
  observations     Json?
  revenueLoss      String?
  revenueBreakdown Json?
  approachMoves    Json?
  minutesAnalysing Int?
  signalBanner     String?
  personalNote     String?
  deliveryMessages Json?
  ctaText          String?
  ctaValue         String?
  brandColour      String?
  logoUrl          String?
  agencyName       String?
  viewCount        Int       @default(0)
  lastViewed       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])
  stripeCustomerId      String?
  stripePriceId         String?
  stripeSubId           String?
  plan                  String    @default("starter")
  status                String    @default("active")
  // Solopreneur trial fields
  isSolopreneur         Boolean   @default(false)
  solopreneurApproved   Boolean   @default(false)
  solopreneurExpiry     DateTime?
  dealClosed            Boolean   @default(false)
  dealClosedAt          DateTime?
  dealValue             Float?
  dealClientName        String?
  dealLeadId            String?
  // Activity tracking
  activityQualified     Boolean   @default(false)
  searchCount           Int       @default(0)
  cardCount             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model SolopreneurApplication {
  id           String   @id @default(cuid())
  userId       String
  email        String
  name         String
  agency       String?
  teamSize     String?
  niche        String?
  monthlySpend String?
  notes        String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model UserEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@unique([userId, type])
}

model Feedback {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  message       String
  implemented   Boolean   @default(false)
  implementedAt DateTime?
  createdAt     DateTime  @default(now())
}

model Proposal {
  id                String             @id @default(cuid())
  slug              String             @unique
  leadId            String
  lead              Lead               @relation(fields: [leadId], references: [id])
  userId            String
  user              User               @relation(fields: [userId], references: [id])
  title             String
  threadSection     String?
  currentState      String?
  visionSection     String?
  planSection       Json?
  beforeAfter       Json?
  investmentContext String?
  closingSection    String?
  depositAmount     Float?
  status            String             @default("draft")
  stripeSessionId   String?
  viewCount         Int                @default(0)
  firstViewedAt     DateTime?
  lastViewedAt      DateTime?
  acceptedAt        DateTime?
  paidAt            DateTime?
  questions         ProposalQuestion[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model ProposalQuestion {
  id          String    @id @default(cuid())
  proposalId  String
  proposal    Proposal  @relation(fields: [proposalId], references: [id])
  visitorName String
  question    String
  answer      String?
  isPublic    Boolean   @default(true)
  answeredAt  DateTime?
  createdAt   DateTime  @default(now())
}

model ServicePackage {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  price       Float
  currency    String   @default("GBP")
  features    Json?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CloseSession {
  id                   String            @id @default(cuid())
  leadId               String
  lead                 Lead              @relation(fields: [leadId], references: [id])
  userId               String
  user                 User              @relation(fields: [userId], references: [id])
  slug                 String            @unique
  status               String            @default("sent")
  questions            Json
  answers              Json?
  discoveryViewedAt    DateTime?
  discoveryCompletedAt DateTime?
  proposalId           String?
  proposalGeneratedAt  DateTime?
  viewCount            Int               @default(0)
  lastViewed           DateTime?
  completionRate       Float?
  sentMessage          String?
  sentChannel          String?
  sentAt               DateTime?
  discoveryAnswers     DiscoveryAnswer[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model DiscoveryAnswer {
  id             String       @id @default(cuid())
  closeSessionId String
  closeSession   CloseSession @relation(fields: [closeSessionId], references: [id])
  questionIndex  Int
  questionText   String
  answer         String
  answeredAt     DateTime     @default(now())
}

model Client {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  leadId          String?
  lead            Lead?           @relation(fields: [leadId], references: [id])
  proposalId      String?
  businessName    String
  ownerName       String?
  email           String?
  phone           String?
  website         String?
  niche           String?
  location        String?
  logoUrl         String?
  status          String          @default("active")
  startDate       DateTime        @default(now())
  contractValue   Float?
  billingCycle    String          @default("monthly")
  nextBillingDate DateTime?
  contractEndDate DateTime?
  healthScore     Int             @default(100)
  healthSignals   Json?
  lastHealthCheck DateTime?
  notes           String?
  tags            Json?
  deliverables    Deliverable[]
  reports         ClientReport[]
  checkIns        ClientCheckIn[]
  activities      ClientActivity[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Deliverable {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  userId      String
  title       String
  description String?
  category    String
  status      String    @default("pending")
  priority    String    @default("medium")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ClientReport {
  id        String    @id @default(cuid())
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id])
  userId    String
  slug      String    @unique
  title     String
  period    String
  content   Json
  status    String    @default("draft")
  sentAt    DateTime?
  viewedAt  DateTime?
  viewCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ClientCheckIn {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  userId      String
  type        String
  notes       String?
  sentiment   String?
  nextAction  String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

model ClientActivity {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  userId      String
  type        String
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
}
