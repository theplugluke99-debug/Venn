generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  email        String        @unique
  name         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  cardIdentity CardIdentity?
  leads        Lead[]
  subscription Subscription?
}

model CardIdentity {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])
  brandColour   String   @default("#C4973F")
  accentColour  String   @default("#E8B44B")
  logoUrl       String?
  agencyName    String?
  agencyTagline String?
  writingStyle  String?
  defaultAngle  String   @default("pain")
  ctaType       String   @default("reply")
  ctaValue      String?
  socialProof   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Lead {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  businessName       String
  ownerName          String?
  location           String
  niche              String
  website            String?
  phone              String?
  email              String?
  googlePlaceId      String?
  googleRating       Float?
  reviewCount        Int?
  reviewSummary      Json?
  instagramHandle    String?
  instagramData      Json?
  websiteAudit       Json?
  techStack          Json?
  intentScore        String   @default("medium")
  intentSignals      Json?
  businessBio        String?
  observations       Json?
  openingLine        String?
  recommendedChannel String?
  suggestedAngle     String?
  status             String   @default("pending")
  jobId              String?
  card               Card?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Card {
  id           String    @id @default(cuid())
  slug         String    @unique
  leadId       String    @unique
  lead         Lead      @relation(fields: [leadId], references: [id])
  userId       String
  headline     String?
  observations Json?
  revenueLoss  String?
  ctaText      String?
  ctaValue     String?
  brandColour  String?
  logoUrl      String?
  agencyName   String?
  viewCount    Int       @default(0)
  lastViewed   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Subscription {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  stripeCustomerId String?
  stripePriceId    String?
  stripeSubId      String?
  plan             String   @default("starter")
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
